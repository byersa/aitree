<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-2.1.xsd">

    <service verb="create" noun="AgendaContainer" type="entity-auto">
        <in-parameters>
            <auto-parameters entity-name="aitree.meeting.AgendaContainer" include="nonpk"/>
        </in-parameters>
        <out-parameters>
            <parameter name="agendaContainerId"/>
        </out-parameters>
    </service>

    <service verb="store" noun="AgendaContainer" type="entity-auto">
        <in-parameters>
            <auto-parameters entity-name="aitree.meeting.AgendaContainer" include="all"/>
        </in-parameters>
        <out-parameters>
            <parameter name="agendaContainerId"/>
        </out-parameters>
    </service>

</services>
