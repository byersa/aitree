<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="component://moqui-ai/xsd/moqui-ai-screen.xsd" require-authentication="false">
    <subscreens default-item="ManageAgendaContainers">
        <subscreens-item name="ManageAgendaContainers" location="component://aitree/screen/aitree/Meetings/ManageAgendaContainers.xml"/>
    </subscreens>
    <widgets>
        <screen-layout id="manage-agenda-containers-layout">
            <screen-header id="h-manage-agenda-containers">
                <label text="Manage Agenda Containers" type="h5"/>
                <dynamic-dialog id="create-container" text="Create Container" icon="add" transition="EditAgendaContainerDialog"/>
            </screen-header>
            <screen-content id="c-manage-agenda-containers">
                <form-list id="AgendaContainerList" list="containerList">
                    <entity-find entity-name="aitree.meeting.AgendaContainer" list="containerList">
                        <field name="agendaContainerId"/>
                        <field name="name"/>
                        <field name="shortName"/>
                        <field name="containerTypeEnumId"/>
                        <field name="statusId"/>
                        <action name="Edit" icon="edit" transition="EditAgendaContainerDialog" parameters="agendaContainerId=${agendaContainerId}"/>
                    </entity-find>
                </form-list>
            </screen-content>
        </screen-layout>
    </widgets>
</screen>