<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" require-authentication="false">
    <parameter name="agendaContainerId"/>

    <transition name="storeAgendaContainer">
        <service-call name="aitree.MeetingServices.store#AgendaContainer" in-map="true"/>
        <default-response type="none"/>
    </transition>

    <actions>
        <if condition="agendaContainerId">
            <entity-find-one entity-name="aitree.meeting.AgendaContainer" value-field="agendaContainer"/>
        </if>
    </actions>

    <widgets>
        <form-single name="EditAgendaContainerForm" map="agendaContainer" transition="storeAgendaContainer">
            <field name="agendaContainerId"><default-field><hidden/></default-field></field>
            <field name="name"><default-field title="Full Name"><text-line size="60"/></default-field></field>
            <field name="shortName"><default-field title="Short Name"><text-line size="30"/></default-field></field>
            
            <field name="containerCategoryEnumId"><default-field title="Category">
                <drop-down allow-empty="true">
                    <entity-options key-field-name="enumId" text="${description}">
                        <entity-find entity-name="moqui.basic.Enumeration">
                            <econdition field-name="enumTypeId" value="AgendaContainerCategory"/>
                            <order-by field-name="description"/>
                        </entity-find>
                    </entity-options>
                </drop-down>
            </default-field></field>
            
            <field name="containerTypeEnumId"><default-field title="Type">
                <drop-down allow-empty="true">
                    <entity-options key-field-name="enumId" text="${description}">
                        <entity-find entity-name="moqui.basic.Enumeration">
                            <econdition field-name="enumTypeId" value="AgendaContainerType"/>
                            <order-by field-name="description"/>
                        </entity-find>
                    </entity-options>
                </drop-down>
            </default-field></field>
            
            <field name="statusId"><default-field title="Status">
                <drop-down allow-empty="false">
                    <entity-options key-field-name="statusId" text="${description}">
                        <entity-find entity-name="moqui.basic.StatusItem">
                            <econdition field-name="statusTypeId" value="AgendaContainerStatus"/>
                            <order-by field-name="description"/>
                        </entity-find>
                    </entity-options>
                </drop-down>
            </default-field></field>
            
            <field name="orgId"><default-field title="Organization">
                <drop-down allow-empty="true">
                    <entity-options key-field-name="partyId" text="${organizationName}">
                        <entity-find entity-name="mantle.party.PartyDetail">
                            <econdition field-name="partyTypeEnumId" value="PtyOrganization"/>
                            <order-by field-name="organizationName"/>
                        </entity-find>
                    </entity-options>
                </drop-down>
            </default-field></field>
            
            <field name="fromDate"><default-field title="From Date"><date-time/></default-field></field>
            <field name="thruDate"><default-field title="Thru Date"><date-time/></default-field></field>
            
            <field name="submitButton"><default-field title="Save Container"><submit/></default-field></field>
        </form-single>
    </widgets>
</screen>
