<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="component://moqui-ai/xsd/moqui-ai-screen.xsd" require-authentication="false">
    <parameter name="name"/>
    <parameter name="containerCategoryEnumId"/>
    <parameter name="containerTypeEnumId"/>
    <parameter name="fromDate"/>
    <parameter name="thruDate"/>

    <transition name="LoadEditAgendaContainerDialog">
        <default-response url="EditAgendaContainerDialog" parameter-map="true" access-re-authorize="true">
            <parameter name="renderMode" value="qjson"/>
            <parameter name="renderTargetOnly" value="true"/>
        </default-response>
    </transition>

    <subscreens>
        <subscreens-item name="EditAgendaContainerDialog" location="component://aitree/screen/aitree/Meetings/ManageAgendaContainers/EditAgendaContainerDialog.xml" menu-include="false"/>
    </subscreens>

    <actions>
        <entity-find entity-name="aitree.meeting.AgendaContainer" list="containerList">
            <search-form-inputs/>
        </entity-find>
    </actions>

    <widgets>
        <screen-layout id="ManageAgendaContainersLayout">
            <screen-header id="ManageAgendaContainersHeader">
                <container-row id="HeaderRow">
                    <row-col class="col-grow"><label text="Manage Agenda Containers" type="h5" id="PageTitle"/></row-col>
                    <row-col class="col-auto">
                        <dynamic-dialog id="CreateContainerDialog" button-text="Create Container" icon="add" transition="LoadEditAgendaContainerDialog" color="primary" title="Create New Agenda Container"/>
                    </row-col>
                </container-row>
            </screen-header>
            <screen-content id="ManageAgendaContainersContent">
                <form-query name="SearchForm">
                    <form-query-field name="name" type="text" operator="begins"/>
                    <form-query-field name="containerCategoryEnumId" type="drop-down" enum-type-id="AgendaContainerCategory"/>
                    <form-query-field name="containerTypeEnumId" type="drop-down" enum-type-id="AgendaContainerType"/>
                    <form-query-field name="fromDate" type="date"/>
                    <form-query-field name="thruDate" type="date"/>
                </form-query>

                <form-list name="AgendaContainerList" list="containerList">
                    <field name="agendaContainerId"><header-field title="ID"/><default-field><display/></default-field></field>
                    <field name="name"><header-field title="Name"/><default-field><display/></default-field></field>
                    <field name="shortName"><header-field title="Short Name"/><default-field><display/></default-field></field>
                    <field name="containerTypeEnumId"><header-field title="Type"/><default-field><display-entity entity-name="moqui.basic.Enumeration"/></default-field></field>
                    <field name="statusId"><header-field title="Status"/><default-field><display-entity entity-name="moqui.basic.StatusItem"/></default-field></field>
                    
                    <field name="edit" align="center"><header-field title="Edit"/>
                        <default-field>
                            <dynamic-dialog id="EditContainerButton" button-text="Edit" icon="edit" transition="LoadEditAgendaContainerDialog">
                                <parameter name="agendaContainerId" from="agendaContainerId"/>
                            </dynamic-dialog>
                        </default-field>
                    </field>
                </form-list>
            </screen-content>
        </screen-layout>
    </widgets>
</screen>