<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="component://moqui-ai/xsd/moqui-ai-screen.xsd" require-authentication="false">
    <subscreens default-item="ManageAgendaContainers">
        <subscreens-item name="ManageAgendaContainers" location="component://aitree/screen/aitree/Meetings/ManageAgendaContainers.xml"/>
        <subscreens-item name="ActiveScreens" location="component://aitree/screen/aitree/Meetings/ActiveScreens.xml"/>
    </subscreens>
    <widgets>
        <screen-layout id="meetings-layout">
            <screen-header id="h-meetings">
                <label text="Staff Meeting" type="h5"/>
                <bp-tabbar id="m-tabs">
                    <bp-tab name="ManageAgendaContainers" text="Manage Containers" icon="settings"/>
                    <bp-tab name="ActiveScreens" text="Active Meetings" icon="play_arrow"/>
                </bp-tabbar>
            </screen-header>
            <screen-content id="c-meetings">
                <subscreens-active/>
            </screen-content>
        </screen-layout>
    </widgets>
</screen>