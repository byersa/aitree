<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="component://moqui-ai/xsd/moqui-ai-screen.xsd" require-authentication="false">
    <subscreens default-item="ManageMeetings">
        <subscreens-item name="ManageMeetings" location="component://aitree/screen/aitree/Meetings/ManageMeetings.xml"/>
        <subscreens-item name="ActiveMeetings" location="component://aitree/screen/aitree/Meetings/ActiveMeetings.xml"/>
    </subscreens>
    <widgets>
        <screen-layout id="meetings-layout">
            <screen-header id="h-meetings">
                <label text="Staff Meeting" type="h5"/>
                <bp-tabbar id="m-tabs">
                    <bp-tab name="ManageMeetings" text="Manage" icon="list"/>
                    <bp-tab name="ActiveMeetings" text="Active" icon="play_arrow"/>
                </bp-tabbar>
            </screen-header>
            <screen-content id="c-meetings">
                <subscreens-active/>
            </screen-content>
        </screen-layout>
    </widgets>
</screen>