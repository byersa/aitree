<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-4.0.xsd"
        default-menu-title="Trend Analysis" default-menu-index="4">

    <parameter name="patientPartyId" required="true"/>
    <parameter name="observationTypeEnumId" default-value="PotVitalsBP"/>

    <actions>
        <entity-find entity-name="nursinghome.medical.PatientObservation" list="trendDataList">
            <econdition field-name="patientPartyId" from="patientPartyId"/>
            <econdition field-name="observationTypeEnumId" from="observationTypeEnumId"/>
            <order-by field-name="observationDate"/>
        </entity-find>
    </actions>

    <widgets>
        <screen-layout>
            <screen-header>
                <label text="Vitals Trend Analysis" type="h5"/>
            </screen-header>
            
            <screen-content>
                <form-single name="TrendFilter" transition=".">
                    <field name="patientPartyId"><default-field><hidden/></default-field></field>
                    <field name="observationTypeEnumId" title="Select Metric">
                        <default-field>
                            <drop-down allow-empty="false">
                                <entity-options entity-name="moqui.basic.Enumeration">
                                    <econdition field-name="enumTypeId" value="PatientObservationType"/>
                                    <order-by field-name="description"/>
                                </entity-options>
                            </drop-down>
                        </default-field>
                    </field>
                    <field name="submitButton"><default-field title="Update Chart"><submit/></default-field></field>
                    <field-layout><field-row><field-ref name="observationTypeEnumId"/><field-ref name="submitButton"/></field-row></field-layout>
                </form-single>

                <container-row>
                    <container-col md="12">
                        <bp-chart type="line" list="trendDataList" 
                                  label-field="observationDate" 
                                  value-field="valueQuantity" 
                                  title="Clinical Trend over Time"/>
                    </container-col>
                </container-row>
            </screen-content>
        </screen-layout>
    </widgets>
</screen>